---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/news/NewsCard.astro";
import { getArticlesByCategory } from "../lib/data";

const articles = getArticlesByCategory("startups", 50);
---

<BaseLayout title="Startups">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">Startups</h1>
    <p class="text-[var(--text-secondary)]">Funding, launches, and startup ecosystem news ({articles.length} articles)</p>
  </div>

  <div class="space-y-4">
    {articles.map((article) => (
      <NewsCard {...article} publicationDate={new Date(article.publicationDate)} />
    ))}
  </div>
</BaseLayout>
