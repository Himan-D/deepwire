---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/news/NewsCard.astro";
import TrendingTopics from "../components/news/TrendingTopics.astro";
import { getTopStories, getTrendTopics, getAllArticles } from "../lib/data";

const topArticles = getTopStories(50);
const trendTopics = getTrendTopics();
const allArticles = getAllArticles();
---

<BaseLayout title="Trending">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">Trending Topics</h1>
    <p class="text-[var(--text-secondary)]">Most discussed topics in AI and DeepTech ({allArticles.length} total articles)</p>
  </div>

  <div class="flex flex-wrap gap-2 mb-8">
    {trendTopics.slice(0, 20).map((trend) => (
      <a
        href={`/search?q=${encodeURIComponent(trend.topic)}`}
        class="trending-tag"
      >
        {trend.topic}
        <span class="ml-1.5 text-xs text-[var(--green)]">+{trend.growthRate}%</span>
      </a>
    ))}
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-8">
    <div class="space-y-4">
      {topArticles.map((article) => (
        <NewsCard {...article} publicationDate={new Date(article.publicationDate)} />
      ))}
    </div>
    <aside class="max-lg:hidden">
      <TrendingTopics trends={trendTopics.slice(0, 10)} period="trending" />
    </aside>
  </div>
</BaseLayout>
