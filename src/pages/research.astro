---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/news/NewsCard.astro";
import { getArticlesByCategory } from "../lib/data";

const articles = getArticlesByCategory("research", 50);
---

<BaseLayout title="Research">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">Research</h1>
    <p class="text-[var(--text-secondary)]">Important research papers and scientific breakthroughs ({articles.length} papers)</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-8">
    <div class="space-y-4">
      {articles.map((article) => (
        <NewsCard {...article} publicationDate={new Date(article.publicationDate)} />
      ))}
    </div>
    <aside class="max-lg:hidden space-y-6">
      <div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-6">
        <h3 class="font-bold mb-3">Quick Links</h3>
        <div class="space-y-2">
          <a href="https://arxiv.org/list/cs.AI/recent" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">arXiv AI →</a>
          <a href="https://arxiv.org/list/cs.LG/recent" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">arXiv ML →</a>
          <a href="https://paperswithcode.com" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Papers With Code →</a>
          <a href="https://www.science.org" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Science →</a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
