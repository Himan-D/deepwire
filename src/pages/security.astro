---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/news/NewsCard.astro";
import { getArticlesByCategory } from "../lib/data";

const articles = getArticlesByCategory("security", 50);
---

<BaseLayout title="Security">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">Cybersecurity</h1>
    <p class="text-[var(--text-secondary)]">Security alerts, vulnerabilities, and threat intelligence</p>
  </div>

  <div class="space-y-4">
    {articles.map((article) => (
      <NewsCard {...article} publicationDate={new Date(article.publicationDate)} />
    ))}
  </div>
</BaseLayout>
