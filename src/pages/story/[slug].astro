---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsCard from "../../components/news/NewsCard.astro";
import { getArticleBySlug, getRelatedArticles, getArticlesByCategory } from "../../lib/data";
import { formatDate } from "../../lib/utils";

export async function getStaticPaths() {
  const { getAllArticles } = await import("../../lib/data");
  const articles = getAllArticles();
  return articles.map((a) => ({
    params: { slug: String(a.id) },
    props: { article: a },
  }));
}

const { article } = Astro.props;
const relatedArticles = getRelatedArticles(article.id, 5);
const sameCategory = getArticlesByCategory(article.category, 5).filter((a) => a.id !== article.id).slice(0, 3);
---

{!article ? (
  <BaseLayout title="Not Found">
    <div class="text-center py-16">
      <h1 class="text-2xl font-bold mb-2">Article Not Found</h1>
    </div>
  </BaseLayout>
) : (
<BaseLayout title={article.title} description={article.excerpt}>
  <article class="max-w-4xl mx-auto">
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="category-tag category-{article.category}">{article.category}</span>
        <span class="text-sm text-[var(--text-tertiary)]">{article.source}</span>
        <span class="text-sm text-[var(--text-tertiary)]">·</span>
        <span class="text-sm text-[var(--text-tertiary)]">{formatDate(new Date(article.publicationDate))}</span>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4">{article.title}</h1>

      <div class="flex items-center gap-3 text-sm text-[var(--text-secondary)] mb-6">
        <span>By {article.author}</span>
        <span>·</span>
        <a href={article.url} target="_blank" rel="noopener" class="text-[var(--accent)] hover:underline">
          Read original →
        </a>
      </div>

      {article.imageUrl && (
        <img src={article.imageUrl} alt="" class="w-full rounded-xl mb-8 max-h-96 object-cover" />
      )}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 mb-12">
      <div>
        <div class="prose prose-sm max-w-none text-[var(--text-secondary)] leading-relaxed">
          <div class="bg-[var(--bg-secondary)] rounded-xl p-6 mb-6 border border-[var(--border)]">
            <h3 class="font-semibold text-[var(--text-primary)] mb-2">TL;DR</h3>
            <p>{article.excerpt}</p>
          </div>

          <p>{article.content}</p>
        </div>

        {article.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-[var(--border)]">
            {article.tags.map((tag) => (
              <a href={`/search?q=${encodeURIComponent(tag)}`} class="trending-tag text-xs">
                {tag}
              </a>
            ))}
          </div>
        )}
      </div>

      <aside class="space-y-6">
        {article.importanceScore > 0 && (
          <div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-5">
            <h4 class="text-sm font-semibold mb-3">Article Intelligence</h4>
            <div class="space-y-3 text-sm">
              <div>
                <span class="text-[var(--text-tertiary)]">Importance</span>
                <div class="flex items-center gap-2 mt-1">
                  <div class="flex-1 h-1.5 bg-[var(--border)] rounded-full overflow-hidden">
                    <div class="h-full bg-[var(--accent)] rounded-full" style={"width:" + article.importanceScore + "%"}></div>
                  </div>
                  <span class="font-mono text-xs">{article.importanceScore}/100</span>
                </div>
              </div>
              <div>
                <span class="text-[var(--text-tertiary)]">Source</span>
                <p class="font-medium">{article.source}</p>
              </div>
              <div>
                <span class="text-[var(--text-tertiary)]">Category</span>
                <p class="font-medium capitalize">{article.category}</p>
              </div>
            </div>
          </div>
        )}

        {relatedArticles.length > 0 && (
          <div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-5">
            <h4 class="text-sm font-semibold mb-3">Related Stories</h4>
            <div class="space-y-3">
              {relatedArticles.slice(0, 4).map((ra) => (
                <a href={`/story/${ra.id}`} class="block text-sm hover:text-[var(--accent)] transition-colors">
                  <div class="line-clamp-2">{ra.title}</div>
                  <div class="text-xs text-[var(--text-tertiary)] mt-0.5">{ra.source}</div>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </article>

  {sameCategory.length > 0 && (
    <section class="mt-12 pt-8 border-t border-[var(--border)]">
      <h2 class="section-header">More in {article.category}</h2>
      <div class="space-y-4">
        {sameCategory.map((a) => (
          <NewsCard {...a} publicationDate={new Date(a.publicationDate)} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
)}
