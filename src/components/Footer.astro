---
import siteConfig from "@/site.config";

export interface Props {
  meta?: string;
  anno?: string;
}

const {
  meta = 'A personal publication &middot; Travels &middot; Technology<br>And everyday notes',
  anno = "You've reached the end. The internet rarely rewards this behavior."
} = Astro.props;
---

<footer class="border-border mt-12 border-t py-8 ">
  <div class="app-layout">
    <div class="flex flex-col items-center">
      <span class="block mb-3 text-xl font-semibold tracking-tight">
        {siteConfig.author}<span class="text-primary font-normal">.</span>
      </span>
      <span class="font-code text-muted-foreground text-balance tracking-wide text-sm text-center leading-relaxed" set:html={meta} />
      <span class="font-annotation block text-primary max-w-70 md:max-w-80 mx-auto mt-6 text-xl md:text-2xl text-center -rotate-1 leading-snug">
        {anno}
      </span>
    </div>
  </div>
</footer>